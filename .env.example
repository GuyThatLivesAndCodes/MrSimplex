# Copy this file to ".env" and fill in your secrets.
# (Do NOT commit your real .env — it's already in .gitignore.)

# Your Discord bot token, from https://discord.com/developers/applications
#   -> your app -> "Bot" -> "Reset Token"
DISCORD_TOKEN=your-discord-bot-token-here

# Your data.guythatlives.net API key (sent as a Bearer token).
SIMPLEX_API_KEY=your-simplex-api-key-here
